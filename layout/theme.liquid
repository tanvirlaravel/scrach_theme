<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ page_title }}</title>
    {{ 'style.css' |  asset_url|  stylesheet_tag }}
    {{ asset_url }}
    {{ content_for_header }}
</head>
<body>
    <nav>
  <ul>
    {% comment %} ৪. শপিফাই মেইন মেনু থেকে লিঙ্কগুলো নিয়ে আসা {% endcomment %}
    {% for link in linklists.main-menu.links %}
      <li><a href="{{ link.url }}">{{ link.title }}</a></li>
    {% endfor %}
  </ul>
</nav>
    <header>
        <h1>{{ shop.name }}</h1>
        <h1>{{ asset_url }}</h1>
        <h2>{{ | asset_img_url: 'medium' }}</h2>
       
    </header>

    <main>
        {{ content_for_layout }}
    </main>

    <footer>
        <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</p>
    </footer>
</body>
</html>